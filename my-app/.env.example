# Database
DATABASE_URL="mysql://blog_chat_user:blog_chat_password@localhost:3306/blog_chat_db"

# BetterAuth
# openssl rand -base64 32 으로 생성
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Social Login (optional - 없으면 해당 소셜 로그인만 비활성화됨)
# Google: https://console.cloud.google.com
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Kakao: https://developers.kakao.com
# Callback URL: http://localhost:3000/api/auth/callback/kakao
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# AWS S3 (이미지 업로드)
# IAM 사용자 Access Key
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# 버킷 리전 (예: ap-northeast-2)
AWS_REGION=""
AWS_S3_BUCKET_NAME=""
